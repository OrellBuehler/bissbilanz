{
	"name": "bissbilanz",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview",
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy url cookie baseLocale --emit-ts-declarations",
		"prepare": "(svelte-kit sync || echo '') && (prek install 2>/dev/null || true)",
		"check": "bun run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && prettier --write .",
		"check:watch": "bun run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"test": "bun --bun vitest run",
		"test:watch": "bun --bun vitest",
		"test:mobile": "bunx playwright test --reporter=list",
		"security": "./scripts/security/scan-all.sh"
	},
	"devDependencies": {
		"@internationalized/date": "^3.10.0",
		"@j178/prek": "^0.3.5",
		"@lucide/svelte": "^0.577.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/table-core": "^8.21.3",
		"@types/bcrypt": "^6.0.0",
		"@types/bun": "^1.3.8",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^25.2.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"bits-ui": "^2.15.5",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.8",
		"embla-carousel-svelte": "^8.6.0",
		"fake-indexeddb": "^6.2.5",
		"formsnap": "^2.0.1",
		"layerchart": "2.0.0-next.46",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"svelte": "^5.48.2",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.3.5",
		"svelte-gestures": "^5.2.2",
		"svelte-sonner": "^1.0.7",
		"sveltekit-superforms": "^2.28.1",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.11",
		"@inlang/paraglide-js": "^2.10.0",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@rodrigodagostino/svelte-sortable-list": "^2.1.10",
		"@sentry/sveltekit": "^10.42.0",
		"@zxing/browser": "^0.1.5",
		"@zxing/library": "^0.21.3",
		"bcrypt": "^6.0.0",
		"dexie": "4",
		"drizzle-orm": "^0.45.1",
		"express-rate-limit": "^8.3.1",
		"hono": "^4.12.5",
		"jose": "^6.1.3",
		"sharp": "^0.34.5",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"overrides": {
		"@hono/node-server": "^1.19.11",
		"rollup": "^4.59.0"
	}
}
